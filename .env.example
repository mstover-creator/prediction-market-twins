# === PolyEdge cross-venue divergence instrument — environment template ===
# Copy to .env and fill in your own credentials. NEVER commit a real .env.
# If your jurisdiction blocks a venue, route that venue's traffic via your own proxy.

# --- Polymarket (CLOB / wallet) ---
POLYGON_WALLET_PRIVATE_KEY=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# --- Polymarket-US (QCEX) apples-to-apples leg ---
# Ed25519-signed; see tape/pmus_auth.py for the expected key format.

# --- Kalshi leg ---
TAPE_KALSHI_KEY_ID=
TAPE_KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_key.pem   # path to YOUR key file (gitignored)
TAPE_ENABLE_KALSHI_FEED=true
# Optional Kalshi tuning (defaults live in tape/listener.py):
# TAPE_KALSHI_REST_URL=
# TAPE_KALSHI_WS_PATH=
# TAPE_KALSHI_CATEGORIES=
# TAPE_KALSHI_MAX_EVENTS=
# TAPE_KALSHI_REQS_PER_SEC=

# --- LLM (twin recognition) — code accepts any one of these names ---
XAI_API_KEY=
# X_AI_API_KEY=
# GROK_API_KEY=

# --- News (optional / legacy) ---
CURRENTSAPI_KEY=
NEWSAPI_KEY=

# --- Telegram alerts (optional) ---
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Local data paths (defaults are repo-relative; override as needed) ---
# TOKEN_OUTCOMES_DB_FILE=./data/token_outcomes.db
